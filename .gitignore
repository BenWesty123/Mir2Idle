# Generated tooling data
tools/generated-data/

# Node
node_modules/

# Built itch package (regenerate with: npm run package:itch)
dist/

# Cloudflare Wrangler local state and deploy config (contains account + DB identifiers)
.wrangler/
tools/stats-worker/wrangler.toml

# Large asset folders — keep local, don't push to GitHub
new content/
tile-review/
outputs/
content-audit/
# Binary media
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.webp
**/*.bmp
**/*.wav
**/*.ogg
**/*.mp3
**/*.Lib
**/*.zip
# The public/ folder IS committed (game assets, atlases, monster data) so the
# game, tests, and CI work from a clean clone. Re-include everything under it,
# overriding the binary-media rules above.
!public/**
# Logs
server.err.log
server.out.log
